# Set Emacs as default application for text and source files.
# Format: bundle_id UTI role

com.local.EmacsclientWrapper public.plain-text all
com.local.EmacsclientWrapper public.text all
com.local.EmacsclientWrapper public.source-code all
com.local.EmacsclientWrapper public.shell-script all
com.local.EmacsclientWrapper public.script all
com.local.EmacsclientWrapper public.unix-executable all

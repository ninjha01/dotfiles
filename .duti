# Set Emacs as default application for code and text files
# Format: bundle_id extension|UTI role

# Text files
org.gnu.Emacs public.plain-text all
org.gnu.Emacs .txt all
org.gnu.Emacs .text all
org.gnu.Emacs .md all
org.gnu.Emacs .markdown all
org.gnu.Emacs .rst all
org.gnu.Emacs .org all

# Configuration files
org.gnu.Emacs .conf all
org.gnu.Emacs .config all
org.gnu.Emacs .ini all
org.gnu.Emacs .cfg all
org.gnu.Emacs .toml all
org.gnu.Emacs .yaml all
org.gnu.Emacs .yml all
org.gnu.Emacs .json all
org.gnu.Emacs .jsonc all
org.gnu.Emacs .xml all

# Shell scripts
org.gnu.Emacs .sh all
org.gnu.Emacs .bash all
org.gnu.Emacs .zsh all
org.gnu.Emacs .fish all
org.gnu.Emacs public.shell-script all

# Python
org.gnu.Emacs .py all
org.gnu.Emacs .pyw all
org.gnu.Emacs .pyx all
org.gnu.Emacs .pyi all

# JavaScript/TypeScript
org.gnu.Emacs .js all
org.gnu.Emacs .jsx all
org.gnu.Emacs .ts all
org.gnu.Emacs .tsx all
org.gnu.Emacs .mjs all
org.gnu.Emacs .cjs all

